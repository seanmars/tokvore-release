{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${PLUGIN_ROOT}/scripts/bridge.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${PLUGIN_ROOT}/scripts/bridge.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${PLUGIN_ROOT}/scripts/bridge.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${PLUGIN_ROOT}/scripts/bridge.py"
          }
        ]
      }
    ]
  }
}
